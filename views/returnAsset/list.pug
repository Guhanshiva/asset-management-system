extends ../layout

block content

  h3 Return Asset List

  a.btn.btn-success.mb-3(href="/return/add")
    | Return Asset

  table.table.table-bordered#returnAssetTable
    thead
      tr
        th Employee Code
        th Employee Name
        th Department
        th Asset Code
        th Asset Name
        th Serial Number
        th Make
        th Model
        th Issue Date
        th Return Date
        th Reason
        th Status
        th Action

block scripts
  script(src="/js/returnAsset.js")